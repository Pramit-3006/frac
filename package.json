{
  "name": "fractureiq-platform",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered fracture analysis platform for X-ray interpretation.",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:gateway": "npm --prefix services/gateway run dev",
    "dev:api": "uvicorn app.main:app --app-dir services/api --reload --port 8000"
  },
  "workspaces": [
    "apps/web",
    "services/gateway"
  ]
}
